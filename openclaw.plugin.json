{
  "id": "athenamem-core",
  "version": "0.2.0",
  "name": "AthenaMem Core",
  "description": "Biomimetic memory stack — structure architecture (modules, sections, vaults, entries), WAL enforcement, contradiction detection, DAG compaction, cross-system recall.",
  "openclaw": {
    "version": ">=2026.3.24-beta.2"
  },
  "entry": "dist/index.js",
  "kind": "tool",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dataDir": {
        "type": "string",
        "description": "Directory for AthenaMem Core data storage"
      },
      "structureMode": {
        "type": "boolean",
        "description": "Enable structure architecture mode",
        "default": true
      }
    }
  },
  "tools": [
    "athenamem_core_create_wing",
    "athenamem_core_create_room",
    "athenamem_core_status",
    "athenamem_core_list_modules",
    "athenamem_core_list_sections",
    "athenamem_core_search",
    "athenamem_core_get_aaak_spec",
    "athenamem_core_add_entry",
    "athenamem_core_delete_entry",
    "athenamem_core_kg_query",
    "athenamem_core_kg_add",
    "athenamem_core_kg_invalidate",
    "athenamem_core_kg_timeline",
    "athenamem_core_check_facts",
    "athenamem_core_resolve_conflict",
    "athenamem_core_diary_write",
    "athenamem_core_diary_read",
    "athenamem_core_traverse",
    "athenamem_core_find_bridges",
    "athenamem_core_recall",
    "athenamem_core_quick_search"
  ],
  "hooks": {
    "before_agent_start": "Session bootstrap + setSession binding",
    "after_tool_call": "WAL checkpoint after each tool",
    "before_prompt_build": "Incremental compaction before context window pressure"
  }
}
