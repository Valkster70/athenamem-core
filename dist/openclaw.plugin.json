{
  "id": "athenamem",
  "version": "0.1.0",
  "name": "AthenaMem",
  "description": "Biomimetic memory stack — palace architecture, WAL enforcement, contradiction detection, DAG compaction, cross-system recall.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "data_dir": {
        "type": "string",
        "default": "/home/chris/.openclaw/workspace/athenamem/data"
      },
      "palace_dir": {
        "type": "string",
        "default": "/home/chris/.openclaw/workspace/athenamem/palace"
      },
      "compact_on_flush": {
        "type": "boolean",
        "default": true
      },
      "contradiction_check": {
        "type": "boolean",
        "default": true
      },
      "auto_wal": {
        "type": "boolean",
        "default": true
      },
      "qmd_path": {
        "type": "string",
        "default": "/home/chris/.cache/qmd"
      },
      "clawvault_path": {
        "type": "string",
        "default": "/home/chris/.openclaw/workspace/memory"
      },
      "hindsight_url": {
        "type": "string",
        "default": "http://127.0.0.1:8888"
      },
      "mnemo_url": {
        "type": "string",
        "default": "http://127.0.0.1:50001"
      }
    }
  },
  "tools": [
    "athenamem_status",
    "athenamem_list_wings",
    "athenamem_list_rooms",
    "athenamem_search",
    "athenamem_get_aaak_spec",
    "athenamem_add_drawer",
    "athenamem_delete_drawer",
    "athenamem_kg_query",
    "athenamem_kg_add",
    "athenamem_kg_invalidate",
    "athenamem_kg_timeline",
    "athenamem_check_facts",
    "athenamem_resolve_conflict",
    "athenamem_diary_write",
    "athenamem_diary_read",
    "athenamem_traverse",
    "athenamem_find_tunnels",
    "athenamem_recall"
  ],
  "hooks": {
    "before_agent_start": "Session bootstrap + setSession binding",
    "after_tool_call": "WAL checkpoint after each tool",
    "before_prompt_build": "Incremental compaction before context window pressure"
  }
}
